  const onDrop = useCallback(async (acceptedFiles: File[]) => {
    const file = acceptedFiles[0]
    if (!file) return

    setUploading(true)
    await new Promise(resolve => setTimeout(resolve, 2000))

    // Mock AI analysis result
    const analysisData = {
      inventory: {
        weapons: [
          { name: 'M416 Glacier', rarity: 'Legendary', level: 6, maxLevel: 7, upgrades: ['Kill Effect', 'Loot Crate', 'Attachment Skin'] },
          { name: 'AKM Gluttonous', rarity: 'Mythic', level: 3, maxLevel: 5, upgrades: ['Scope Skin'] },
          { name: 'Kar98K Fool', rarity: 'Legendary', level: 8, maxLevel: 8, upgrades: ['All'] },
          { name: 'SCAR-L Dream Weaver', rarity: 'Legendary', level: 4, maxLevel: 7, upgrades: ['Kill Effect'] }
        ],
        xSuits: [
          { name: 'Pharaoh X-Suit', rarity: 'Mythic', level: 2, maxLevel: 3 },
          { name: 'Crimson X-Suit', rarity: 'Mythic', level: 1, maxLevel: 3 }
        ],
        outfits: [
          { name: 'Godzilla Evolved', rarity: 'Mythic' },
          { name: "Santa's Helper", rarity: 'Legendary' },
          { name: 'Phoenix Ascendant', rarity: 'Mythic' }
        ],
        vehicles: [
          { name: 'Dragon Spirit', type: 'Car', rarity: 'Mythic' },
          { name: 'Phantom Jet', type: 'Airplane', rarity: 'Legendary' }
        ],
        emotes: ['Dance Royal', 'Celebration', 'Victory Spin', 'Floss Dance'],
        lobbyBackgrounds: ['Neon City', 'Ancient Temple', 'Cyber Dojo']
      },
      account: {
        level: 78,
        rank: 'Crown II',
        highestRank: 'Ace Dominator',
        rpLevel: 52,
        popularity: 12450,
        ucBalance: 320,
        stats: {
          matches: 1240,
          wins: 187,
          top10: 543,
          kd: 2.8,
          headshots: 342
