// ============================================
// SENSITIVITY GENERATOR
// ============================================
function SensitivityGenerator() {
  const [device, setDevice] = useState({ model: '', processor: 'Snapdragon 8 Gen 2', ram: '8GB', gyroscope: 'on' })
  const [sensitivities, setSensitivities] = useState<any>(null)

  const generate = () => {
    const baseSens = device.processor.includes('Snapdragon') ? 85 : 75
    const gyroMultiplier = device.gyroscope === 'on' ? 1.2 : 1
    setSensitivities({
      camera: Math.floor(baseSens * 0.9), ads: Math.floor(baseSens * 0.85), gyroscope: Math.floor(baseSens * 0.6 * gyroMultiplier),
      redDot: Math.floor(baseSens * 0.7), holo: Math.floor(baseSens * 0.68), scope2x: Math.floor(baseSens * 0.5),
      scope3x: Math.floor(baseSens * 0.42), scope4x: Math.floor(baseSens * 0.35), scope6x: Math.floor(baseSens * 0.28), scope8x: Math.floor(baseSens * 0.22)
    })
  }

  return (
    <div className="space-y-6">
      <div className="grid md:grid-cols-2 gap-4">
        <div><label className="flex items-center gap-2 text-sm text-gray-400"><Smartphone className="w-4 h-4" />Device Model</label><input type="text" placeholder="e.g., iPhone 14 Pro, Samsung S23" className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white" onChange={e => setDevice({...device, model: e.target.value})} /></div>
        <div><label className="flex items-center gap-2 text-sm text-gray-400"><Cpu className="w-4 h-4" />Processor</label><select className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white" onChange={e => setDevice({...device, processor: e.target.value})}><option>Snapdragon 8 Gen 2</option><option>Snapdragon 888</option><option>Apple A16 Bionic</option><option>MediaTek Dimensity 9000</option></select></div>
        <div><label className="flex items-center gap-2 text-sm text-gray-400"><Activity className="w-4 h-4" />RAM</label><select className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white" onChange={e => setDevice({...device, ram: e.target.value})}><option>6GB</option><option>8GB</option><option>12GB</option><option>16GB</option></select></div>
        <div><label className="flex items-center gap-2 text-sm text-gray-400"><RotateCw className="w-4 h-4" />Gyroscope</label><select className="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white" onChange={e => setDevice({...device, gyroscope: e.target.value})}><option value="on">Always On</option><option value="off">Off</option><option value="ads">ADS Only</option></select></div>
      </div>
      <button onClick={generate} className="w-full py-3 bg-gradient-to-r from-cyan-500 to-purple-600 rounded-lg font-semibold text-white hover:opacity-90 transition">Generate AI-Optimized Sensitivities</button>
